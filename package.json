{
  "name": "palmi",
  "version": "0.1.0",
  "private": true,
  "description": "A quiet social app for small circles of friends.",
  "scripts": {
    "app": "cd app && npm start",
    "app:ios": "cd app && npm run ios",
    "app:android": "cd app && npm run android",
    "app:typecheck": "cd app && npx tsc --noEmit",
    "web:dev": "cd apps/web && npm run dev",
    "web:build": "cd apps/web && npm run build",
    "web:start": "cd apps/web && npm run start",
    "web:typecheck": "cd apps/web && npm run typecheck",
    "functions:deploy": "cd supabase && supabase functions deploy",
    "functions:test": "cd supabase/functions/curate-question && deno run --allow-read validator.test.ts && deno run --allow-read integration.test.ts",
    "functions:smoke": "cd supabase/functions/curate-question && deno run --allow-net --allow-env smoke_live.ts",
    "db:reset": "cd supabase && supabase db reset",
    "db:push": "cd supabase && supabase db push",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "author": "Brandon Deneault",
  "license": "MIT"
}
