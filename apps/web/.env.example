# Public — exposed to browser. Safe.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to browser. Used by server actions + admin dashboard.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret between the Next.js server action and the Supabase Edge Function.
# Set the same value in Vercel and in Supabase Edge Function secrets.
WAITLIST_EMAIL_SECRET=

# Supabase Edge Function secrets, not Vercel env vars:
# RESEND_API_KEY=re_xxx
# WAITLIST_FROM_EMAIL="Palmi <noreply@palmi.app>"
# WAITLIST_REPLY_TO=hi@palmi.app

# Hardcoded waitlist counter for v1 (replace with materialized view later).
NEXT_PUBLIC_WAITLIST_COUNT=2847
