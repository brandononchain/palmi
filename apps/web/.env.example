# Public — exposed to browser. Safe.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to browser. Used by server actions + admin dashboard.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Intake webhook base URL for Palmi forms.
PALMI_INTAKE_WEBHOOK_URL=

# Optional shared secret sent as X-Webhook-Secret by server actions.
PALMI_WEBHOOK_SECRET=

# Legacy secrets can stay wherever they are currently configured if still used outside this app.

# Hardcoded waitlist counter for v1 (replace with materialized view later).
NEXT_PUBLIC_WAITLIST_COUNT=2847
